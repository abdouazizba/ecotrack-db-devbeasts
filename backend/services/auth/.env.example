# Auth Service Environment Variables

# Application
NODE_ENV=development
SERVER_PORT=3001

# Database PostgreSQL
DB_HOST=auth-db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ecotrack_auth

# RabbitMQ Configuration (Event-Driven Architecture)
RABBITMQ_URL=amqp://ecotrack:ecotrack123@rabbitmq:5672

# JWT Secrets - CHANGEZ CES VALEURS EN PRODUCTION!
JWT_SECRET=your-very-secret-jwt-key-change-this-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=your-very-secret-refresh-token-key-change-this-in-production
REFRESH_TOKEN_EXPIRY=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001


# Logging
LOG_LEVEL=debug
