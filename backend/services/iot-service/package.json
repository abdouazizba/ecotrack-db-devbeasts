{
  "name": "iot-service",
  "version": "1.0.0",
  "description": "IoT Gateway Service - Receives sensor measurements and forwards to container-service",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "simulate:sensor": "node scripts/simulate-single-sensor.js",
    "simulate:multi": "node scripts/simulate-multiple-sensors.js",
    "simulate:crisis": "node scripts/simulate-crisis-scenarios.js",
    "simulate:load-test": "node scripts/load-test.js",
    "simulate:help": "echo 'Usage: npm run simulate:sensor [options]' && echo 'Options: --type=REMPLISSAGE --interval=5000 --gateway' && echo '' && echo 'Or use npm run simulate:multi --count=10 --interval=5000 --duration=3600000'"
  },
  "keywords": ["iot", "gateway", "sensors", "measurements", "ecotrack"],
  "author": "DevBeasts",
  "license": "MIT",
  "dependencies": {
    "amqplib": "^0.10.3",
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
